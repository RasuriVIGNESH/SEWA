# ══════════════════════════════════════════════════════════════
# SEWA Frontend — Environment Variables TEMPLATE
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The .env file is gitignored.
# ══════════════════════════════════════════════════════════════

# ── Backend API URL ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── App Settings ─────────────────────────────────────────────
VITE_APP_NAME=SEWA
VITE_APP_VERSION=1.0.0
VITE_VITALS_INTERVAL_MS=3000
VITE_MAX_CHART_READINGS=50
